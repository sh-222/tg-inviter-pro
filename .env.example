# TG Inviter Pro Environment Configuration

# Core settings
APP_TITLE="TG Inviter Pro"
DEBUG=False

# Admin Dashboard Credentials (Required for Web UI)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# SQLite Database is stored in data/db.sqlite3 by default
# DB_URL=sqlite:///app/data/db.sqlite3

# Limits (in seconds)
MIN_DELAY_SECONDS=300
MAX_DELAY_SECONDS=600

# Daily limit per account (default is 50)
DAILY_INVITE_LIMIT=50
